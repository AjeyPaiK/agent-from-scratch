# Ollama (local LLM)
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# Langfuse (optional — traces, scores, session grouping in the UI)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Emit INFO turn summaries while Langfuse tracing is on (default: DEBUG only)
# AGENT_LOG_TURNS=true

# Oracle snapshot for tool-accuracy scoring
# ANNEX_SNAPSHOT_DIR=data/annex_snapshots/default
